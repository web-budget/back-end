<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="202104042335" author="${arthur}">
        <createTable tableName="users" schemaName="administration">
            <column name="id" autoIncrement="true" type="bigint">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="external_id" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="smallint">
                <constraints nullable="false"/>
            </column>
            <column name="created_on" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="last_update" type="timestamp"/>

            <column name="name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="default_language" type="varchar(5)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="roles" schemaName="administration">
            <column name="id" autoIncrement="true" type="bigint">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="external_id" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="smallint">
                <constraints nullable="false"/>
            </column>
            <column name="created_on" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="last_update" type="timestamp"/>

            <column name="name" type="varchar(45)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="grants" schemaName="administration">
            <column name="id" autoIncrement="true" type="bigint">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="external_id" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="smallint">
                <constraints nullable="false"/>
            </column>
            <column name="created_on" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="last_update" type="timestamp"/>

            <column name="id_user" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="id_role" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint constraintName="fk_users_on_grants"
                                 baseColumnNames="id_user" baseTableName="grants" baseTableSchemaName="administration"
                                 referencedTableName="users" referencedTableSchemaName="administration"
                                 referencedColumnNames="id"/>
        <addForeignKeyConstraint constraintName="fk_roles_on_grants"
                                 baseColumnNames="id_role" baseTableName="grants"
                                 baseTableSchemaName="administration"
                                 referencedTableName="roles" referencedTableSchemaName="administration"
                                 referencedColumnNames="id"/>

        <addUniqueConstraint columnNames="external_id" tableName="users" schemaName="administration"/>
        <addUniqueConstraint columnNames="id,external_id" tableName="users" schemaName="administration"/>
        <addUniqueConstraint columnNames="email" tableName="users" schemaName="administration"/>

        <addUniqueConstraint columnNames="external_id" tableName="grants" schemaName="administration"/>
        <addUniqueConstraint columnNames="id,external_id" tableName="grants" schemaName="administration"/>

        <addUniqueConstraint columnNames="external_id" tableName="roles" schemaName="administration"/>
        <addUniqueConstraint columnNames="id,external_id" tableName="roles" schemaName="administration"/>
    </changeSet>

    <changeSet id="202104042340" author="arthurshakal@gmail.com">
